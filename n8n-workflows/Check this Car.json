    {
      "parameters": {
        "jsCode": "const rawText = items[0].json.output;\nconst vehicle = items[0].json;\n\nfunction linkify(text) {\n  // [text](url) -> real clickable anchor tag\n  return text.replace(\n    /\\[([^\\]]+)\\]\\((https?:\\/\\/[^\\s)]+)\\)/g,\n    '<a href=\"$2\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color:#2563eb; text-decoration:underline;\">$1</a>'\n  );\n}\n\nfunction boldify(text) {\n  let result = linkify(text);\n  result = result.split('**').map((part, i) => i % 2 === 1 ? `<strong>${part}</strong>` : part).join('');\n  result = result.split('*').map((part, i) => i % 2 === 1 ? `<em style=\"color:#666; font-size:0.9em;\">${part}</em>` : part).join('');\n  return result;\n}\n\nfunction markdownToHtml(md) {\n  const lines = md.split('\\n');\n  let html = '';\n  let inList = false;\n  for (let line of lines) {\n    let trimmed = line.trim();\n    if (trimmed.startsWith('### ')) {\n      if (inList) { html += '</ul>'; inList = false; }\n      html += `<h3 style=\"color:#1a1a1a; margin-top:24px;\">${boldify(trimmed.slice(4))}</h3>`;\n      continue;\n    }\n    if (trimmed.startsWith('## ')) {\n      if (inList) { html += '</ul>'; inList = false; }\n      html += `<h2 style=\"color:#1a1a1a; border-bottom:2px solid #2563eb; padding-bottom:6px; margin-top:28px;\">${boldify(trimmed.slice(3))}</h2>`;\n      continue;\n    }\n    if (trimmed === '---') {\n      if (inList) { html += '</ul>'; inList = false; }\n      html += '<hr style=\"border:none; border-top:1px solid #ddd; margin:20px 0;\">';\n      continue;\n    }\n    if (trimmed.startsWith('* ') || trimmed.startsWith('- ')) {\n      if (!inList) { html += '<ul style=\"padding-left:20px; line-height:1.6;\">'; inList = true; }\n      html += `<li>${boldify(trimmed.slice(2))}</li>`;\n      continue;\n    }\n    const numberedMatch = trimmed.match(/^\\d+\\.\\s+(.*)/);\n    if (numberedMatch) {\n      if (!inList) { html += '<ul style=\"padding-left:20px; line-height:1.6;\">'; inList = true; }\n      html += `<li>${boldify(numberedMatch[1])}</li>`;\n      continue;\n    }\n    if (inList) { html += '</ul>'; inList = false; }\n    if (trimmed === '') continue;\n    html += `<p style=\"line-height:1.6; margin:10px 0;\">${boldify(trimmed)}</p>`;\n  }\n  if (inList) html += '</ul>';\n  return html;\n}\n\nconst bodyHtml = markdownToHtml(rawText);\n\nreturn [{\n  json: {\n    make: vehicle.make,\n    model: vehicle.model,\n    registration: vehicle.registration,\n    riskLevel: vehicle.riskLevel,\n    riskScore: vehicle.riskScore,\n    reportHtml: bodyHtml,\n  },\n}];"
      },

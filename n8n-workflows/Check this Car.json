    {
      "parameters": {
        "jsCode": "const vehicle = Array.isArray(items[0].json) ? items[0].json[0] : items[0].json;\n\nconst tests = vehicle.motTests\n  .filter(t => t.odometerValue !== null)\n  .map(t => ({\n    date: t.completedDate,\n    mileage: parseInt(t.odometerValue),\n    result: t.testResult,\n  }))\n  .sort((a, b) => new Date(a.date) - new Date(b.date));\n\nconst flags = [];\n\nfor (let i = 1; i < tests.length; i++) {\n  const prev = tests[i - 1];\n  const curr = tests[i];\n  const mileageDiff = curr.mileage - prev.mileage;\n  const daysDiff = (new Date(curr.date) - new Date(prev.date)) / (1000 * 60 * 60 * 24);\n\n  if (mileageDiff < 0) {\n    flags.push(`Mileage DECREASED between ${prev.date.slice(0,10)} and ${curr.date.slice(0,10)} (${prev.mileage} → ${curr.mileage}) — possible clocking`);\n  } else if (daysDiff > 0 && (mileageDiff / daysDiff) > 200) {\n    flags.push(`Unusually high mileage jump: ${mileageDiff} miles in ${Math.round(daysDiff)} days between ${prev.date.slice(0,10)} and ${curr.date.slice(0,10)}`);\n  }\n}\n\nconst totalFails = vehicle.motTests.filter(t => t.testResult === 'FAILED').length;\nconst dangerousDefects = vehicle.motTests.flatMap(t => t.defects).filter(d => d.dangerous === true);\n\n// Calculate a risk score based on multiple factors\nlet riskScore = 0;\nriskScore += totalFails * 2;\nriskScore += flags.length * 5;\nriskScore += dangerousDefects.length * 4;\n\n// Categorize into a simple risk level\nlet riskLevel = 'LOW';\nif (riskScore >= 8) {\n  riskLevel = 'HIGH';\n} else if (riskScore >= 3) {\n  riskLevel = 'MEDIUM';\n}\n\nreturn [{\n  json: {\n    make: vehicle.make,\n    model: vehicle.model,\n    registration: vehicle.registration,\n    firstUsedDate: vehicle.firstUsedDate,\n    totalTests: vehicle.motTests.length,\n    totalFails: totalFails,\n    mileageFlags: flags,\n    dangerousDefectCount: dangerousDefects.length,\n    latestMileage: tests[tests.length - 1]?.mileage,\n    riskScore: riskScore,\n    riskLevel: riskLevel,\n    rawMotTests: vehicle.motTests,\n  },\n}];"
      },
